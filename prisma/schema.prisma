generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum UserRole {
  STUDENT
  TEACHER
  ADMIN
}

enum AssignmentMode {
  MULTIPLE_CHOICE
  TYPED_RESPONSE
  MIXED
}

enum AssignmentSourceType {
  DIRECT_WORDS
  SOURCE_GROUP
}

enum AssignmentQuestionFormat {
  MULTIPLE_CHOICE
  TYPED_RESPONSE
}

enum AssignmentPromptType {
  WORD_TO_DEFINITION
  DEFINITION_TO_WORD
  SENTENCE_CONTEXT
}

enum SubmissionKind {
  STUDENT_SUBMIT
  AUTO_SUBMIT
}

model User {
  id                 String              @id @default(cuid())
  name               String?
  email              String?             @unique
  emailVerified      DateTime?
  image              String?
  role               UserRole            @default(STUDENT)
  roleSelectedAt     DateTime?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  accounts           Account[]
  sessions           Session[]
  progress           UserWordProgress[]
  studySessions      StudySession[]
  bookmarks          Bookmark[]
  streak             Streak?
  achievements       UserAchievement[]
  classesTaught      Classroom[]         @relation("TeacherClasses")
  classMemberships   ClassMembership[]   @relation("StudentMemberships")
  membershipRemovals ClassMembership[]   @relation("MembershipRemovedBy")
  assignmentsCreated Assignment[]        @relation("TeacherAssignments")
  assignmentAttempts AssignmentAttempt[] @relation("StudentAssignmentAttempts")
  adminRoleChanges   RoleAuditLog[]      @relation("RoleChangedBy")
  roleChangeHistory  RoleAuditLog[]      @relation("RoleChangedFor")

  @@map("Users")
}

model Account {
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@id([identifier, token])
}

model Word {
  id              Int                @id @default(autoincrement())
  word            String             @unique
  definition      String
  exampleSentence String
  sourceGroup     String?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  progress        UserWordProgress[]
  bookmarks       Bookmark[]
  assignmentWords AssignmentWord[]
  assignmentQuestions AssignmentQuestion[]
  assignmentResponses AssignmentResponse[]

  @@map("Words")
}

model UserWordProgress {
  id                String   @id @default(cuid())
  userId            String
  wordId            Int
  masteryScore      Float    @default(0)
  attempts          Int      @default(0)
  correctAnswers    Int      @default(0)
  incorrectAnswers  Int      @default(0)
  lastReviewed      DateTime?
  averageResponseMs Float    @default(0)
  lastResponseMs    Int?
  needsRetry        Boolean  @default(false)
  isWeak            Boolean  @default(false)
  missedCount       Int      @default(0)
  lastResult        String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  word              Word     @relation(fields: [wordId], references: [id], onDelete: Cascade)

  @@unique([userId, wordId], map: "userId_wordId")
  @@index([userId, masteryScore])
  @@map("UserWordProgress")
}

model StudySession {
  id             String   @id
  userId         String
  mode           String
  totalQuestions Int
  correctAnswers Int
  startedAt      DateTime
  endedAt        DateTime
  durationSec    Int
  accuracy       Float
  createdAt      DateTime @default(now())
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, startedAt])
  @@map("Sessions")
}

model Bookmark {
  id        String   @id @default(cuid())
  userId    String
  wordId    Int
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  word      Word     @relation(fields: [wordId], references: [id], onDelete: Cascade)

  @@unique([userId, wordId], map: "userId_wordId_bookmark")
  @@index([userId, createdAt])
  @@map("Bookmarks")
}

model Achievement {
  id          String            @id @default(cuid())
  key         String            @unique
  title       String
  description String
  points      Int               @default(10)
  users       UserAchievement[]

  @@map("Achievements")
}

model UserAchievement {
  id            String      @id @default(cuid())
  userId        String
  achievementId String
  unlockedAt    DateTime    @default(now())
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  achievement   Achievement @relation(fields: [achievementId], references: [id], onDelete: Cascade)

  @@unique([userId, achievementId], map: "userId_achievementId")
  @@index([userId, unlockedAt])
}

model Streak {
  id            String    @id @default(cuid())
  userId        String    @unique
  currentStreak Int       @default(0)
  longestStreak Int       @default(0)
  lastStudyDate DateTime?
  updatedAt     DateTime  @updatedAt
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("Streaks")
}

model Classroom {
  id          String              @id @default(cuid())
  name        String
  joinCode    String              @unique
  teacherId   String
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  teacher     User                @relation("TeacherClasses", fields: [teacherId], references: [id], onDelete: Restrict)
  memberships ClassMembership[]
  assignments Assignment[]
  attempts    AssignmentAttempt[]

  @@index([teacherId, createdAt])
}

model ClassMembership {
  id          String    @id @default(cuid())
  classId     String
  studentId   String
  joinedAt    DateTime  @default(now())
  removedAt   DateTime?
  removedById String?
  classroom   Classroom @relation(fields: [classId], references: [id], onDelete: Cascade)
  student     User      @relation("StudentMemberships", fields: [studentId], references: [id], onDelete: Restrict)
  removedBy   User?     @relation("MembershipRemovedBy", fields: [removedById], references: [id], onDelete: SetNull)

  @@unique([classId, studentId], map: "class_student")
  @@index([studentId, removedAt])
  @@index([classId, removedAt])
}

model Assignment {
  id                  String               @id @default(cuid())
  classId             String
  teacherId           String
  title               String
  instructions        String?
  dueAt               DateTime
  allowLateSubmissions Boolean             @default(false)
  questionCount       Int
  mode                AssignmentMode
  sourceType          AssignmentSourceType
  sourceLabel         String?
  firstStartedAt      DateTime?
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  classroom           Classroom            @relation(fields: [classId], references: [id], onDelete: Cascade)
  teacher             User                 @relation("TeacherAssignments", fields: [teacherId], references: [id], onDelete: Restrict)
  words               AssignmentWord[]
  questions           AssignmentQuestion[]
  attempts            AssignmentAttempt[]

  @@index([classId, dueAt])
  @@index([teacherId, createdAt])
}

model AssignmentWord {
  id           String     @id @default(cuid())
  assignmentId String
  wordId       Int
  position     Int
  assignment   Assignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  word         Word       @relation(fields: [wordId], references: [id], onDelete: Restrict)

  @@unique([assignmentId, position], map: "assignment_word_position")
  @@unique([assignmentId, wordId], map: "assignment_word_word")
}

model AssignmentQuestion {
  id               String                   @id @default(cuid())
  assignmentId     String
  wordId           Int
  position         Int
  promptType       AssignmentPromptType
  format           AssignmentQuestionFormat
  prompt           String
  subPrompt        String?
  choices          Json?
  answerText       String
  answerAliases    Json?
  sentenceWithBlank String?
  createdAt        DateTime                 @default(now())
  assignment       Assignment               @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  word             Word                     @relation(fields: [wordId], references: [id], onDelete: Restrict)
  responses        AssignmentResponse[]

  @@unique([assignmentId, position], map: "assignment_question_position")
  @@index([assignmentId, format])
}

model AssignmentAttempt {
  id               String               @id @default(cuid())
  assignmentId     String
  classId          String
  studentId        String
  startedAt        DateTime?
  submittedAt      DateTime?
  submissionKind   SubmissionKind?
  submittedLate    Boolean              @default(false)
  totalQuestions   Int
  questionsCompleted Int                @default(0)
  firstTryCorrect  Int                  @default(0)
  finalCorrect     Int                  @default(0)
  totalAttempts    Int                  @default(0)
  totalResponseMs  Int                  @default(0)
  lastActivityAt   DateTime?
  autoSubmittedAt  DateTime?
  masteryAppliedAt DateTime?
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt
  assignment       Assignment           @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  classroom        Classroom            @relation(fields: [classId], references: [id], onDelete: Restrict)
  student          User                 @relation("StudentAssignmentAttempts", fields: [studentId], references: [id], onDelete: Restrict)
  responses        AssignmentResponse[]

  @@unique([assignmentId, studentId], map: "assignment_student_attempt")
  @@index([classId, studentId])
  @@index([studentId, submittedAt])
}

model AssignmentResponse {
  id              String            @id @default(cuid())
  attemptId       String
  questionId      String
  questionPosition Int
  wordId          Int
  firstAnswer     String?
  finalAnswer     String?
  firstCorrect    Boolean?
  isCorrect       Boolean?
  attempts        Int               @default(0)
  responseMs      Int               @default(0)
  completedAt     DateTime?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  attempt         AssignmentAttempt @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  question        AssignmentQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)
  word            Word              @relation(fields: [wordId], references: [id], onDelete: Restrict)

  @@unique([attemptId, questionId], map: "attempt_question_response")
  @@index([attemptId, completedAt])
}

model RoleAuditLog {
  id           String   @id @default(cuid())
  targetUserId String
  changedById  String
  previousRole UserRole
  newRole      UserRole
  createdAt    DateTime @default(now())
  targetUser   User     @relation("RoleChangedFor", fields: [targetUserId], references: [id], onDelete: Cascade)
  changedBy    User     @relation("RoleChangedBy", fields: [changedById], references: [id], onDelete: Cascade)

  @@index([targetUserId, createdAt])
  @@index([changedById, createdAt])
}
